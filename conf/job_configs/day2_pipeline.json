name: nestle_day2_sql_server_pipeline
description: Day 2 - SQL Server incremental processing with watermark

tasks:
  - task_key: bronze_load_day2
    notebook_path: /src/ingestion_framework_scripts/09_nb_load_day2_incremental
    timeout_seconds: 900
    parameters:
      source_id: "sql_sales_transactions"
      day: "2"
    
  - task_key: dq_validation_day2
    notebook_path: /src/data_quality_framework/07_nb_dq_validation_day2
    depends_on:
      - task_key: bronze_load_day2
    timeout_seconds: 600
    
  - task_key: watermark_update_day2
    notebook_path: /src/control_table_scripts/08_nb_update_watermark_day2
    depends_on:
      - task_key: dq_validation_day2
    timeout_seconds: 300
    
  - task_key: silver_scd2_day2
    notebook_path: /src/silver/14_nb_silver_scd2_day2_incremental
    depends_on:
      - task_key: watermark_update_day2
    timeout_seconds: 900
    
  - task_key: gold_refresh_day2
    notebook_path: /src/gold/15_nb_gold_day2_refresh
    depends_on:
      - task_key: silver_scd2_day2
    timeout_seconds: 900

schedule:
  quartz_cron_expression: "0 3 * * ?"
  timezone_id: "UTC"

timeout_seconds: 5400
max_retries: 1

notification_settings:
  email_notifications:
    on_failure: ["raina.samiksha@nestle.com"]